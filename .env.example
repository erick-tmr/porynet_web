# Copy this file to .env and adjust as needed. .env is gitignored.
# dotenv loads it at Rails boot in development + test. Production should
# inject the same variables via the host/PaaS env, not via .env.
#
# Precedence: real shell env > .env (dotenv won't override existing values).

# === Database (read by config/database.yml) ===
# Match what compose.yaml exposes locally; override per-machine if you point
# at a different Postgres.
DATABASE_HOST=localhost
DATABASE_USER=porynet_web
DATABASE_PASSWORD=porynet_web
# Override the Postgres port (default 5432). Set this if a local Postgres
# already listens on 5432 and you remap the compose.yaml port binding.
# DATABASE_PORT=5432

# === Rails server ===
# Puma threads per worker + AR connection pool size (config/database.yml).
# RAILS_MAX_THREADS=5

# Port that Rails / Puma listens on (config/puma.rb, Procfile.dev).
# PORT=3000

# === Background jobs (solid_queue) ===
# Number of solid_queue worker processes (config/queue.yml).
# JOB_CONCURRENCY=1

# === Images (Cloudflare R2) ===
# Static images are served from R2 (see the Images bullet in CLAUDE.md). Dev/test
# read the bucket, endpoint, and public host from config.x (committed in
# config/environments/*.rb); the R2 write keys used by deploy/upload-images.sh live
# in the default Rails credentials (bin/rails credentials:edit; dev reads them
# automatically), NOT here. Serving public R2 objects needs no keys at all. Only
# production takes an env var, the public host, injected via the host/PaaS env (see
# below), not this file.

# === Production secrets ===
# Set in your deployment environment, NOT in a committed file.
# Read by the `production:` block in config/database.yml:
# PORYNET_WEB_DATABASE_PASSWORD=
# Public host images are served from in production (config/environments/production.rb):
# R2_PUBLIC_HOST=

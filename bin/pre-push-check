#!/usr/bin/env bash
#
# Pre-push gate: mirrors the CI gates locally so nothing red lands on
# origin/main. Runs rubocop, brakeman, bundler-audit, importmap audit, reek
# (advisory), gitleaks (when installed), semgrep diff-mode (when semgrep or
# docker is available), the Rails suite, undercover changed-line coverage, the
# Vitest JS suite, then the Python map-generator suite (ruff + pytest, when a
# pokeyellow checkout is present). Run this manually before `git push`.
#
# Usage:        bin/pre-push-check
# Skip tests:   SKIP_TESTS=1 bin/pre-push-check   (faster — useful for docs-only;
#               also skips undercover, which needs the coverage the suite produces)
# Bail fast:    set -e exits on the first failure; output identifies which step.
#
set -e

ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

step() { printf '\n\033[1;34m==> %s\033[0m\n' "$*"; }
ok()   { printf '\033[1;32m✓ %s\033[0m\n' "$*"; }

step "rubocop"
bin/rubocop
ok "rubocop"

step "brakeman"
bin/brakeman --no-pager -q
ok "brakeman"

step "bundler-audit"
bin/bundler-audit
ok "bundler-audit"

step "importmap audit"
bin/importmap audit
ok "importmap audit"

step "reek (changed files, advisory)"
CHANGED_RB="$(git diff --name-only --diff-filter=ACMR origin/main...HEAD -- 'app/**/*.rb' 'lib/**/*.rb' | tr '\n' ' ')"
if [ -n "$CHANGED_RB" ]; then
  bundle exec reek --force-exclusion $CHANGED_RB || true
else
  printf '  (no changed Ruby files vs origin/main)\n'
fi
ok "reek"

step "gitleaks"
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --no-banner --redact --config .gitleaks.toml
  ok "gitleaks"
else
  printf '  (skipped — gitleaks not installed; `brew install gitleaks`)\n'
fi

# Mirrors CI's Semgrep (new findings) job. Prefers a local install, falls back
# to docker, skips if neither is present. Same config + suppression filter as
# .github/workflows/ci.yml — if it passes here it should pass there.
step "semgrep (diff-mode, new findings only)"
if command -v semgrep >/dev/null 2>&1; then
  SEMGREP_RUN=(semgrep)
elif command -v docker >/dev/null 2>&1; then
  SEMGREP_RUN=(docker run --rm -v "$ROOT":/src -w /src returntocorp/semgrep:1.165.0 semgrep)
else
  SEMGREP_RUN=()
fi
if [ ${#SEMGREP_RUN[@]} -eq 0 ]; then
  printf '  (skipped — install semgrep or docker; `pipx install semgrep` or `brew install --cask docker`)\n'
else
  mkdir -p tmp
  BASE="$(git merge-base origin/main HEAD)"
  "${SEMGREP_RUN[@]}" scan \
    --config p/ruby --config p/security-audit \
    --metrics off --sarif --output tmp/semgrep.sarif \
    --baseline-commit "$BASE" >/dev/null
  UNSUPPRESSED='[.runs[].results[]? | select((.suppressions // []) | length == 0)]'
  COUNT=$(jq -r "$UNSUPPRESSED | length" tmp/semgrep.sarif)
  if [ "$COUNT" -gt 0 ]; then
    jq -r "$UNSUPPRESSED"' | .[] |
      "---\nRULE: \(.ruleId)\nFILE: \(.locations[0].physicalLocation.artifactLocation.uri):\(.locations[0].physicalLocation.region.startLine)\nCODE: \((.locations[0].physicalLocation.region.snippet.text // "(no snippet)") | gsub("\n"; " "))\nMSG:  \(.message.text | gsub("\n"; " "))"
    ' tmp/semgrep.sarif
    printf '\n\033[1;31m✗ semgrep — %s new finding(s); fix or add a justified `# nosemgrep: <rule-id>`\033[0m\n' "$COUNT"
    exit 1
  fi
  ok "semgrep"
fi

if [ "${SKIP_TESTS:-}" = "1" ]; then
  step "tests (skipped via SKIP_TESTS=1)"
else
  step "tests"
  bin/rails test
  ok "tests"

  step "undercover (coverage of changed lines)"
  bundle exec undercover --compare origin/main
  ok "undercover"

  step "js unit tests (vitest)"
  if command -v npm >/dev/null 2>&1; then
    [ -d node_modules ] || npm ci
    npm run test:js
    ok "js unit tests"
  else
    printf '  (skipped — npm not installed)\n'
  fi

  # Mirrors CI's "Python tool (map generator)" job. The suite reads the pokeyellow disassembly
  # and silently skips itself when that is absent, so this reports the skip rather than passing
  # quietly. CI clones the pinned tools/maps/.pokeyellow-ref, so green here matches green there.
  step "python map generator (ruff + pytest)"
  PY_ROOT="${POKEYELLOW:-$HOME/Code/pokeyellow}"
  if ! command -v python3 >/dev/null 2>&1; then
    printf '  (skipped: python3 not installed)\n'
  elif ! python3 -c 'import pytest' >/dev/null 2>&1; then
    printf '  (skipped: `pip install -r tools/maps/requirements-dev.txt`)\n'
  elif [ ! -f "$PY_ROOT/constants/map_constants.asm" ]; then
    printf '  (skipped: no pokeyellow checkout at %s; `git clone --depth 1 https://github.com/pret/pokeyellow ~/Code/pokeyellow`)\n' "$PY_ROOT"
  else
    if python3 -c 'import ruff' >/dev/null 2>&1 || command -v ruff >/dev/null 2>&1; then
      python3 -m ruff check tools/maps
    else
      printf '  (ruff not installed, lint skipped)\n'
    fi
    PY_COV=""
    if python3 -c 'import pytest_cov' >/dev/null 2>&1; then
      PY_COV="--cov --cov-report=term --cov-fail-under=87"
    fi
    (cd tools/maps && POKEYELLOW="$PY_ROOT" python3 -m pytest -q -rs $PY_COV)
    ok "python map generator"
  fi
fi

# The golden test above proves the manifest still matches the game data, but it goes green again
# the moment you regenerate, however many maps moved. This says *which* maps moved and holds them
# to the `Manifest-drift:` trailer on this branch, so collateral damage cannot ride along.
step "generator regression (declared drift vs origin/main)"
MANIFEST="app/models/walkthrough/yellow_maps.json"
CHANGED_PY="$(git diff --name-only --diff-filter=ACMR origin/main...HEAD -- tools/maps "$MANIFEST" | tr '\n' ' ')"
if [ -z "$CHANGED_PY" ]; then
  printf '  (no generator or manifest changes vs origin/main)\n'
else
  printf '  changed: %s\n\n' "$CHANGED_PY"
  mkdir -p tmp
  git show "origin/main:$MANIFEST" > tmp/base-manifest.json
  git log origin/main..HEAD --format=%B > tmp/branch-commits.txt
  if ! python3 tools/maps/manifest_diff.py tmp/base-manifest.json "$MANIFEST" \
       --expect-commits tmp/branch-commits.txt; then
    printf '\n\033[1;31m✗ manifest drift does not match the `Manifest-drift:` trailer on this branch\033[0m\n'
    exit 1
  fi
fi
ok "generator regression"

printf '\n\033[1;32m✓ All pre-push checks passed — safe to push.\033[0m\n'

<section id="features" class="pn-features">
  <div class="pn-eyebrow-label">01 · THE KIT</div>
  <h2 class="pn-h2">A collection tracker that finally does it all.</h2>
  <div class="pn-features__grid">
    <% @features.each do |feature| %>
      <div class="pn-card">
        <div class="pn-card__head">
          <span class="pn-badge"><%= feature.num %></span>
          <span class="pn-card__tag"><%= feature.tag %></span>
        </div>
        <h3 class="pn-card__title"><%= feature.title %></h3>
        <p class="pn-card__desc"><%= feature.desc %></p>
      </div>
    <% end %>
  </div>
</section>

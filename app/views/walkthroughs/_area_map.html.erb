<section class="pn-wt-section pn-wt-maps">
  <% loc.area_maps.each do |area| %>
    <div class="pn-mm-block" data-controller="map-markers"
         data-map-markers-game-value="<%= @game.slug %>"
         data-map-markers-map-value="<%= area.name %>"
         data-map-markers-native-w-value="<%= area.width %>"
         data-map-orient="<%= area.landscape? ? "landscape" : "portrait" %>">
      <div class="pn-mm-head">
        <div>
          <div class="pn-eyebrow-label">
            <%= t("walkthrough.ui.map_markers_eyebrow", count: area.markers.size) %>
          </div>
          <% if area.floor? %><div class="pn-mm-head__floor"><%= area.floor %></div><% end %>
        </div>
        <div class="pn-mm-counter">
          <%= t("walkthrough.ui.map_ticked") %>
          <span data-map-markers-target="counterDone">0</span> / <%= area.tickable_count %>
        </div>
      </div>

      <div class="pn-mm-controls">
        <div class="pn-mm-filters">
          <button type="button" class="pn-mm-pill" data-cat="all" aria-pressed="true"
                  data-map-markers-target="filter" data-action="click->map-markers#filter">
            <span class="pn-mm-pill__swatch pn-mm-pill__swatch--all" aria-hidden="true"></span>
            <%= t("walkthrough.ui.map_filter_all") %>
            <span class="pn-mm-pill__count"><%= area.markers.size %></span>
          </button>
          <% Walkthrough::MAP_CATEGORIES.each do |cat| %>
            <% count = area.marker_counts[cat].to_i %>
            <% next if count.zero? %>
            <button type="button" class="pn-mm-pill" data-cat="<%= cat %>" aria-pressed="false"
                    data-map-markers-target="filter" data-action="click->map-markers#filter">
              <span class="pn-mm-pill__swatch pn-mm-pill__swatch--<%= cat %>" aria-hidden="true"></span>
              <%= t("walkthrough.ui.map_cat_#{cat}") %>
              <span class="pn-mm-pill__count"><%= count %></span>
            </button>
          <% end %>
        </div>
        <button type="button" class="pn-mm-toggle is-on" aria-pressed="true"
                data-map-markers-target="labelToggle" data-action="click->map-markers#toggleLabels">
          <%= t("walkthrough.ui.map_labels") %>
          <span class="pn-mm-toggle__on"><%= t("walkthrough.ui.map_labels_on") %></span>
          <span class="pn-mm-toggle__off"><%= t("walkthrough.ui.map_labels_off") %></span>
        </button>
      </div>

      <%= render "map_howto", place: "top" %>

      <div class="pn-mm-split">
        <figure class="pn-mm-frame">
          <figcaption class="pn-mm-titlebar">
            <span class="pn-mm-titlebar__name">◈ <%= loc.name.upcase %></span>
            <span class="pn-mm-titlebar__note"><%= t("walkthrough.ui.map_note") %></span>
          </figcaption>
          <div class="pn-mm-viewport">
            <div class="pn-mm-canvas" data-map-markers-target="canvas">
              <%= r2_image_tag area.image, alt: "", class: "pn-mm-canvas__img", loading: "lazy" %>
              <div class="pn-mm-layer" data-map-markers-target="layer">
                <% area.markers.each do |marker| %>
                  <%= render "map_marker", marker: marker %>
                <% end %>
              </div>
            </div>
          </div>
        </figure>

        <aside class="pn-mm-side">
          <%= render "map_howto", place: "side" %>
          <%= render "map_legend", area: area %>
        </aside>
      </div>
    </div>
  <% end %>
</section>

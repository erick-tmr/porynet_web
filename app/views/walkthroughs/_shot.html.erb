<div class="pn-wt-shot <%= shot.map? ? "pn-wt-shot--map" : "pn-wt-shot--step" %>">
  <% if shot.map? %>
    <div class="pn-wt-shot__map" data-controller="map-markers">
      <%= r2_image_tag shot.image, alt: "", class: "pn-wt-shot__img", loading: "lazy" %>
      <% shot.markers.each do |mk| %>
        <span class="pn-wt-map__marker pn-wt-map__marker--<%= mk.kind %>" data-map-markers-target="marker"
              data-x="<%= mk.x_pct %>" data-y="<%= mk.y_pct %>">
          <span class="pn-wt-map__dot" aria-hidden="true"></span>
          <span class="pn-wt-map__label"><%= mk.label %></span>
        </span>
      <% end %>
    </div>
  <% else %>
    <div class="pn-wt-shot__ph"><%= t("walkthrough.ui.shot_placeholder") %></div>
  <% end %>
  <span class="pn-wt-shot__label"><%= shot.label %></span>
</div>

# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files (except the committed example).
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key
/config/credentials/*.key


# Ignore SimpleCov coverage output.
/coverage/

# Ignore Node modules (Vitest JS unit tests; app JS still ships via importmap).
/node_modules/

# Ignore the local PokeAPI/sprites checkout (source for committed sprites; not tracked).
/vendor/pokeapi-sprites/

# Images are served from Cloudflare R2, not committed. Keep them locally for uploads
# (deploy/upload-images.sh); they're re-derivable from vendor/pokeapi-sprites. The dir
# itself stays via .keep so Propshaft's image load path survives a fresh clone.
/app/assets/images/*.png
/app/assets/images/**/*.png

# generated map QA previews (renders live in R2)
/tools/maps/qa/

# python bytecode
__pycache__/
*.pyc
